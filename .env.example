# ── Embedding ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── LLM providers (optional — users can also enter keys in the UI) ─────────────
OPENAI_API_KEY=your-openai-api-key

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key     # Settings → API → service_role
SUPABASE_ANON_KEY=your-anon-key                # Settings → API → anon public

# ── Database setup (only needed once, for setup_db.py) ────────────────────────
# Find at: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[your-db-password]@db.[project-ref].supabase.co:5432/postgres
